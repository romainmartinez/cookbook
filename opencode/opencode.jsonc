{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  "permission": {
    "bash": {
      "git push": "ask",
      "git push *": "ask",
    },
  },

  "experimental": {
    "disable_paste_summary": true,
  },

  "provider": {
    "azure-foundry-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Azure AI Foundry (Anthropic)",
      "options": {
        "baseURL": "https://ogcds-foundry.services.ai.azure.com/anthropic/v1",
        "apiKey": "{env:AZURE_FOUNDRY_API_KEY}",
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (Azure)",
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
          "cost": {
            "input": 5,
            "output": 25,
            "cache_read": 0.5,
            "cache_write": 6.25,
            "context_over_200k": {
              "input": 10,
              "output": 37.5,
              "cache_read": 1,
              "cache_write": 12.5,
            },
          },
        },
      },
    },
    "azure-cognitive-services": {
      "options": {
        "resourceName": "ogcds-foundry",
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex (Azure)",
          "limit": {
            "context": 256000,
            "output": 32000,
          },
          "cost": {
            "input": 1.75,
            "output": 14,
            "cache_read": 0.175,
          },
        },
      },
    },
  },

  "plugin": ["@mohak34/opencode-notifier@latest"],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--channel=beta",
      ],
      "enabled": false,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "nuxt-ui": {
      "type": "remote",
      "url": "https://ui.nuxt.com/mcp",
      "enabled": false,
    },
    "intervals-icu": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "{env:HOME}/Documents/intervals-mcp-server",
        "--env-file",
        "{env:HOME}/Documents/intervals-mcp-server/.env",
        "mcp",
        "run",
        "{env:HOME}/Documents/intervals-mcp-server/src/intervals_mcp_server/server.py",
      ],
      "timeout": 15000,
      "enabled": false,
    },
  },
}

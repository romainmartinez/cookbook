{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  "permission": {
    "bash": {
      "git push": "ask",
      "git push *": "ask",
    },
  },

  "experimental": {
    "disable_paste_summary": true,
  },

  "provider": {
    "azure-foundry": {
      "npm": "@ai-sdk/anthropic",
      "name": "Azure AI Foundry",
      "options": {
        "baseURL": "https://ogcds-foundry.services.ai.azure.com/anthropic/v1",
        "apiKey": "{env:AZURE_FOUNDRY_API_KEY}",
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (Azure)",
          "limit": {
            "context": 1000000,
            "output": 32000,
          },
          "cost": {
            "input": 5,
            "output": 25,
            "cache_read": 0.5,
            "cache_write": 6.25,
            "context_over_200k": {
              "input": 10,
              "output": 37.5,
              "cache_read": 1,
              "cache_write": 12.5,
            },
          },
        },
      },
    },
  },

  "plugin": ["@mohak34/opencode-notifier@latest"],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--channel=beta",
      ],
      "enabled": false,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "nuxt-ui": {
      "type": "remote",
      "url": "https://ui.nuxt.com/mcp",
      "enabled": false,
    },
  },
}

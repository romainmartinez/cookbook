# shell
shell-integration = fish
shell-integration-features = no-cursor, sudo

# behavior
auto-update = check
maximize = true
quit-after-last-window-closed = true
confirm-close-surface = false
mouse-hide-while-typing = true
# this is just available for linux for now.
# notify-on-command-finish = always
# notify-on-command-finish-action = bell,notify

# visual
theme = TokyoNight Storm
font-family = "JetBrains Mono"
font-size = 14
adjust-cell-height = 20%
window-colorspace = "display-p3"
macos-titlebar-style = "tabs"
window-padding-balance = true
unfocused-split-opacity = 0.5

# keybindings
#
# tabs:
#   Cmd+T                new tab
#   Cmd+W                close tab
#   Cmd+Shift+[  ]      switch tab
#   Ctrl+Shift+[  ]     move tab
#
# splits:
#   Cmd+D                split right
#   Cmd+Shift+D          split down
#   Cmd+[  ]            navigate splits
#   Cmd+Ctrl+Arrows      resize split
#   Cmd+Shift+Enter      toggle split zoom
#
keybind = super+shift+[=previous_tab
keybind = super+shift+]=next_tab
keybind = ctrl+shift+[=move_tab:-1
keybind = ctrl+shift+]=move_tab:1
keybind = global:ctrl+shift+alt+super+d=toggle_quick_terminal

# quick terminal
quick-terminal-position = center
quick-terminal-size = 80%,80%
quick-terminal-animation-duration = 0
